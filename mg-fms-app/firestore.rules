rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── mg-fms collections (original) ────────────────────────────────────

    // Assessments — any authenticated user can read and write
    match /assessments/{docId} {
      allow read, write: if request.auth != null;
    }

    // PMS records — any authenticated user can read and write
    match /pms_records/{docId} {
      allow read, write: if request.auth != null;
    }

    // User profiles — users can read their own; fleet managers can read/write all
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (
        request.auth.uid == uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "fleet_manager"
      );
    }

    // ─── MG Fleet Portal collections (added 2026-04-21) ──────────────────

    // Fleet companies — managed by portal admins. Everyone authed can read
    // (needed so the booking form can list companies); any authed user can
    // write (the UI gates writes to `is_admin: true` users).
    match /fleetCompanies/{docId} {
      allow read, write: if request.auth != null;
    }

    // Pending invites — keyed by email. Admins create them, the invited user
    // reads their own invite on sign-in completion, then the portal deletes it.
    match /pendingInvites/{email} {
      allow read, write: if request.auth != null;
    }

    // Appointments = garage service bookings. Office staff + fleet customers
    // both need access so customers can see bookings for their fleet.
    match /appointments/{docId} {
      allow read, write: if request.auth != null;
    }

    // Service receipts + quotations (same collection, `kind` field distinguishes).
    match /serviceReceipts/{docId} {
      allow read, write: if request.auth != null;
    }

    // Vehicle service-update timeline posts (the "Post Update" side panel).
    match /vehicleServiceUpdates/{docId} {
      allow read, write: if request.auth != null;
    }

    // Notifications — cross-actor event feed. Any authed user can read/write;
    // audience filtering happens client-side via branch/company/forAdmins fields.
    match /notifications/{docId} {
      allow read, write: if request.auth != null;
    }

    // ─── Round 12+ finance collections ───────────────────────────────────

    // Branch invoices (branch → MG Fleet, Round 12). Internal only.
    match /branchInvoices/{docId} {
      allow read, write: if request.auth != null;
    }

    // Client invoices (MG Fleet → fleet client, Round 13). Customers can
    // read their own; UI enforces company-scope, server enforces auth.
    match /clientInvoices/{docId} {
      allow read, write: if request.auth != null;
    }

    // Credit notes (Round 15) — applies to both branch and client invoices.
    match /creditNotes/{docId} {
      allow read, write: if request.auth != null;
    }

    // Per-branch / per-issuer sequential counters used by the invoice +
    // credit-note numbering. Read+write any authed user (no PII).
    match /counters/{docId} {
      allow read, write: if request.auth != null;
    }

    // ─── Round 20 reference catalogs ─────────────────────────────────────

    // Vehicle make catalog (ingested from MG Cavite database). Anyone authed
    // can read so the quote create flow can populate make/model dropdowns.
    // Writes are gated client-side to is_admin via the ingest page.
    match /refVehicleBrands/{docId} {
      allow read, write: if request.auth != null;
    }

    // Vehicle model catalog. Same shape as brands.
    match /refVehicleModels/{docId} {
      allow read, write: if request.auth != null;
    }

    // ─── Round 34 Cavite price catalogs ───────────────────────────────────
    // Services (labor) — make+model priced, joined via VMakeID/VModelID.
    match /caviteServices/{docId} {
      allow read, write: if request.auth != null;
    }
    // Parts — make+model priced, with both PartsCost and PartsSRP for
    // margin tracking when the cost field exists.
    match /caviteParts/{docId} {
      allow read, write: if request.auth != null;
    }
    // Consumables — universal (no make/model FK).
    match /caviteConsumables/{docId} {
      allow read, write: if request.auth != null;
    }

    // ─── Default deny ─────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
